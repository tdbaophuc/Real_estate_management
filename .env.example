# Copy this file to .env before starting Docker Compose.
DB_NAME=real_estate
DB_USERNAME=real_estate
DB_PASSWORD=change-me-local
DB_ROOT_PASSWORD=change-me-root-local
DB_PORT=3306
DB_URL=jdbc:mysql://localhost:3306/real_estate?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

REDIS_PORT=6379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-local
MINIO_BUCKET=real-estate
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
